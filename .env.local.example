# lawn (frame.tridenteventgroup.ca) — env template
# Fill in, then rename to .env.local

# --- Convex (generated by `bunx convex dev` on first run) ---
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# --- Clerk ---
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Mux (video encode + playback) ---
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=

# --- Backblaze B2 (source-of-truth storage) ---
# S3-compatible credentials for bucket `teg-frame`
BACKBLAZE_BUCKET_NAME=teg-frame
BACKBLAZE_ACCESS_KEY_ID=
BACKBLAZE_SECRET_ACCESS_KEY=
BACKBLAZE_ENDPOINT=https://s3.us-west-004.backblazeb2.com
BACKBLAZE_REGION=us-west-004
# Optional — only set if you want public bucket URLs (we use signed URLs, so leave blank)
# BACKBLAZE_PUBLIC_URL=

# --- Stripe (OPTIONAL — skip for internal use) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_BASIC_MONTHLY=
# STRIPE_PRICE_PRO_MONTHLY=
